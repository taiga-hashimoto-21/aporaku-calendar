# Database
# ローカル例（macOS Homebrew Postgres）: postgresql://{ユーザー名}@localhost:5432/schedule_tool?schema=public
# DB 作成: createdb schedule_tool  →  npm run db:push
DATABASE_URL="postgresql://user:password@localhost:5432/schedule_tool?schema=public"

# Auth.js
# ローカル: http://localhost:3002 / 本番: https://calendar-app.me
AUTH_SECRET="change-me-to-random-string"
NEXTAUTH_SECRET="change-me-to-random-string"
NEXTAUTH_URL="http://localhost:3002"
AUTH_URL="http://localhost:3002"

# 公開予約リンクの表示・コピー用（ローカル開発でも本番ドメインを出す）
PUBLIC_CALENDAR_BASE_URL="https://calendar-app.me"

# 本番デプロイ時（Vercel 等）:
# NEXTAUTH_URL="https://calendar-app.me"
# AUTH_URL="https://calendar-app.me"

# Google OAuth (login + Calendar API)
# Console 設定: docs/GOOGLE-OAUTH.md 参照
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Zoom OAuth（User-managed General app）
# Redirect URI は Marketplace の Development に登録したものと一致させる
# 例: http://localhost:3002/api/auth/callback/zoom
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""
# 省略時は NEXTAUTH_URL + /api/auth/callback/zoom
# localhost で 4,700 が出る場合は 127.0.0.1 を使う（Marketplace 側も同じ値に）
# 例: http://127.0.0.1:3002/api/auth/callback/zoom
ZOOM_REDIRECT_URI=""

# slug 生成（アポラク SQIDS_ALPHABET と同一推奨）
SQIDS_ALPHABET=""

# アポラク連携
APORAKU_API_SECRET=""
APORAKU_WEBHOOK_URL=""
APORAKU_WEBHOOK_SECRET=""

# Token encryption (32-byte hex string)
ENCRYPTION_KEY=""

# Admin console（メール + パスワード）
# パスワードは平文を置かず、bcrypt ハッシュを ADMIN_PASSWORD_HASH に設定
# 生成例: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# 注意: Next.js の .env は $ を変数展開するため、ハッシュ内の $ は \$ と書く
# 例: ADMIN_PASSWORD_HASH=\$2b\$12\$....
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""
