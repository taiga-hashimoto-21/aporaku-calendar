# Database
# ローカル例（macOS Homebrew Postgres）: postgresql://{ユーザー名}@localhost:5432/schedule_tool?schema=public
# DB 作成: createdb schedule_tool  →  npm run db:push
DATABASE_URL="postgresql://user:password@localhost:5432/schedule_tool?schema=public"

# Auth.js
# ローカル: http://localhost:3002 / 本番: https://calendar-app.me
AUTH_SECRET="change-me-to-random-string"
NEXTAUTH_SECRET="change-me-to-random-string"
NEXTAUTH_URL="http://localhost:3002"
AUTH_URL="http://localhost:3002"

# 本番デプロイ時（Vercel 等）:
# NEXTAUTH_URL="https://calendar-app.me"
# AUTH_URL="https://calendar-app.me"

# Google OAuth (login + Calendar API)
# Console 設定: docs/GOOGLE-OAUTH.md 参照
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Zoom OAuth (Phase 2)
ZOOM_CLIENT_ID=""
ZOOM_CLIENT_SECRET=""

# slug 生成（アポラク SQIDS_ALPHABET と同一推奨）
SQIDS_ALPHABET=""

# アポラク連携
APORAKU_API_SECRET=""
APORAKU_WEBHOOK_URL=""
APORAKU_WEBHOOK_SECRET=""

# Token encryption (32-byte hex string)
ENCRYPTION_KEY=""
